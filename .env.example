# Platform Configuration
OMNIROUTE_PORT=42000
OPENDESIGN_PORT=43000
CLAUDE_CODE_VERSION=2.1.214

# User Context for Volume Permissions (WSL/Linux compatibility)
# These will be automatically synced by scripts/bootstrap.sh
USER_UID=1000
USER_GID=1000

# Shared Runtime Paths (Relative to repository root or absolute)
WORKSPACE_PATH=./shared/workspace
CLAUDE_CONFIG_PATH=./shared/claude
ANTIGRAVITY_CONFIG_PATH=./shared/antigravity
NPM_CACHE_PATH=./shared/npm
GENERAL_CACHE_PATH=./shared/cache
SSH_PATH=./shared/ssh
SHARED_CONFIG_PATH=./shared/config

# VS Code Server
VSCODE_PORT=44000
VSCODE_PASSWORD=password
